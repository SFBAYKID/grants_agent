# grants_agent environment template.
# Copy to `.env` and fill in real values. The real `.env` is git-ignored — NEVER commit it.
# Every value below is a placeholder only.

# --- LLM: relevance scoring + contact extraction ---
ANTHROPIC_API_KEY=

# --- Grant: the Slack chatbot (see config/grant_slack_manifest.yaml) ---
SLACK_BOT_TOKEN=            # xoxb-...  Bot User OAuth Token (from OAuth & Permissions after install)
SLACK_APP_TOKEN=           # xapp-...  App-Level Token with connections:write (Socket Mode)
SLACK_SIGNING_SECRET=      # verifies inbound request signatures
SLACK_CHANNEL_ID=          # channel ID where Grant posts the weekly digest
PERSEQUOR_USER_ID=         # Slack member ID of @Persequor — makes handoff mentions ping

# --- Firecrawl: site crawl for contact enrichment ---
FIRECRAWL_API_KEY=         # fc-...

# --- Grant/RFP data sources ---
SAM_API_KEY=               # sam.gov -> Workspace -> Account Details -> Public API Key (Chase; email OTP)

# --- Salesforce (CRM cross-reference for Grant: "you contacted them N days ago", account links) ---
# TEST against the SANDBOX (test.salesforce.com). PRODUCTION uses a SEPARATE Connected App + creds.
# Recommended auth: JWT Bearer flow with a dedicated least-privilege integration user (cron-friendly).
SALESFORCE_LOGIN_URL=https://test.salesforce.com   # production: https://login.salesforce.com
SALESFORCE_SANDBOX_NAME=
SALESFORCE_MY_DOMAIN_URL=
SALESFORCE_CLIENT_ID=          # Connected App consumer key
SALESFORCE_CLIENT_SECRET=      # Connected App consumer secret
SALESFORCE_USERNAME=           # dedicated integration user (query-focused, NOT an admin login)
SALESFORCE_JWT_KEY_PATH=       # path to private key for JWT Bearer; OR use the two below instead
SALESFORCE_PASSWORD=
SALESFORCE_SECURITY_TOKEN=

# --- Database ---
# Phase 1: local SQLite. Phase 4: DigitalOcean managed Postgres, scoped to the grants tenant ONLY.
DATABASE_URL=sqlite:///grant_watch.db
