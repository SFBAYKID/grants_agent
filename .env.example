# grants_agent environment template.
# Copy to `.env` and fill in real values. The real `.env` is git-ignored — NEVER commit it.
# Every value below is a placeholder only.

# --- LLM: relevance scoring + contact extraction ---
ANTHROPIC_API_KEY=
# Optional override for Grant's conversation model (default: claude-sonnet-5).
# GRANT_MODEL=

# --- Grant: the Slack chatbot (see config/grant_slack_manifest.yaml) ---
SLACK_BOT_TOKEN=            # xoxb-...  Bot User OAuth Token (from OAuth & Permissions after install)
SLACK_APP_TOKEN=           # xapp-...  App-Level Token with connections:write (Socket Mode)
SLACK_SIGNING_SECRET=      # verifies inbound request signatures
SLACK_CHANNEL_ID=          # stable channel ID for Monarch Bot Playground only
PERSEQUOR_USER_ID=         # Slack member ID of @Persequor — makes handoff mentions ping

# --- Firecrawl: site crawl for contact enrichment ---
FIRECRAWL_API_KEY=         # fc-...

# --- Grant/RFP data sources ---
SAM_API_KEY=               # sam.gov -> Workspace -> Account Details -> Public API Key (Chase; email OTP)
# Blank means all 50 states plus DC; comma-separated codes narrow a local/test poll.
GRANT_WATCH_STATES=

# --- Salesforce (CRM cross-reference for Grant: "you contacted them N days ago", account links) ---
# TEST against the SANDBOX (test.salesforce.com). PRODUCTION uses a SEPARATE Connected App + creds.
# Auth implemented by Grant: OAuth client credentials with a dedicated least-privilege
# integration user configured as the Connected App's run-as user.
SALESFORCE_LOGIN_URL=https://test.salesforce.com   # production: https://login.salesforce.com
SALESFORCE_SANDBOX_NAME=
SALESFORCE_MY_DOMAIN_URL=
SALESFORCE_CLIENT_ID=          # Connected App consumer key
SALESFORCE_CLIENT_SECRET=      # Connected App consumer secret

# --- Salesforce Campaign writer (SEPARATE Connected App + least-privilege user) ---
# Keep disabled through preview/shadow testing. Writer permissions: read validation
# objects; CREATE only Campaign, CampaignMemberStatus, Lead, and CampaignMember.
# Never grant update/delete on Account, Contact, Opportunity, Task, or existing records.
SALESFORCE_CAMPAIGN_WRITES_ENABLED=0
SALESFORCE_WRITE_MY_DOMAIN_URL=https://your-domain--monarchdev.sandbox.my.salesforce.com
SALESFORCE_WRITE_CLIENT_ID=
SALESFORCE_WRITE_CLIENT_SECRET=
SALESFORCE_WRITE_ORG_ID=
SALESFORCE_WRITE_EXPECT_SANDBOX=1
# Comma-separated public/private Grant channels. DMs and all other channels are read-only.
GRANT_SALESFORCE_WRITE_CHANNEL_IDS=

# --- Grants production droplet (the grants-ops-guardian's ONLY door; scoped grants tenant) ---
# The guardian connects with an explicit, grants-only SSH command — NO ~/.ssh/config alias, so
# nothing global on the machine changes:
#   ssh -i ~/.ssh/grants_droplet -o IdentitiesOnly=yes "$GRANTS_DROPLET_USER@$GRANTS_DROPLET_HOST"
# IdentitiesOnly=yes presents ONLY the dedicated grants key (~/.ssh/grants_droplet), so the admin key
# (id_ed25519) loaded in the ssh-agent is NEVER offered. These two below are the whole connection.
GRANTS_DROPLET_HOST=          # droplet IP/host of the shared box where the grants tenant lives
GRANTS_DROPLET_USER=          # the non-sudo grants tenant Unix user (e.g. grantwatch)

# --- Grants production droplet (the grants-ops-guardian's ONLY door; scoped grants tenant) ---
# The guardian connects with an explicit, grants-only SSH command — NO ~/.ssh/config alias, so
# nothing global on the machine changes:
#   ssh -i ~/.ssh/grants_droplet -o IdentitiesOnly=yes "$GRANTS_DROPLET_USER@$GRANTS_DROPLET_HOST"
# IdentitiesOnly=yes presents ONLY the dedicated grants key (~/.ssh/grants_droplet), so the admin key
# (id_ed25519) loaded in the ssh-agent is NEVER offered. These two below are the whole connection.
GRANTS_DROPLET_HOST=          # droplet IP/host of the shared box where the grants tenant lives
GRANTS_DROPLET_USER=          # the non-sudo grants tenant Unix user (e.g. grantwatch)

# --- Database ---
# Phase 1: local SQLite. Phase 4: DigitalOcean managed Postgres, scoped to the grants tenant ONLY.
DATABASE_URL=sqlite:///grant_watch.db

# TEST MODE: when set, all outreach email is addressed here instead of real contacts
# (real contact still displayed). Clear to go live.
OUTREACH_TEST_EMAIL=

# Grant -> Persequor outreach intake (localhost on the shared droplet)
PERSEQUOR_API_URL=http://127.0.0.1:8002
PERSEQUOR_API_KEY=            # shared secret, identical in both projects' .env

# --- Google Sheets export (Grant-owned; email stays Persequor's, data export is Grant's) ---
# Service-account JSON key (gitignored under secrets/); the account is a Content Manager on the
# "Grant Exports" shared drive so it can create/share export sheets without any personal storage.
GOOGLE_SA_KEY_PATH=secrets/google_sheets_sa.json
GRANT_EXPORTS_DRIVE_ID=       # the "Grant Exports" shared drive id (files.create parent)
